# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Model Configuration
MODEL_DIR=../timeseries/models_recursive
HYBRID_MODEL_PATH=../timeseries/out/recursive/recursive_model.joblib
BLEND_WEIGHTS_PATH=../timeseries/models_recursive/blend_weights.json

# Business Parameters
VEHICLE_CAPACITY_DEFAULT=5
SAFETY_FACTOR_BASE=1.1
SAFETY_FACTOR_BETA=0.05
REPLAN_INTERVAL_MINUTES=30

# Database
DATABASE_URL=sqlite:///./transport_orders.db
# DATABASE_URL=postgresql://user:password@localhost:5432/transport_db

# Monitoring
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Feature flags
ENABLE_DYNAMIC_SAFETY_FACTOR=true
ENABLE_SMART_PRIORITIZATION=true
ENABLE_AUTO_REPLAN=false
SHADOW_MODE=true
